@model WebAppTattoo.Models.Client

@{
    ViewData["Title"] = "Historico do cliente";
    var tattoos = Model.Tattoos.OrderByDescending(t => t.SessionDate).ToList();
    var totalPaid = tattoos.Sum(t => t.ValuePaid);
}

<section class="page-header">
    <div>
        <div class="page-kicker">Cliente</div>
        <h1>@Model.Name</h1>
        <p class="page-description">Historico do cliente e sessoes realizadas.</p>
    </div>
    <div class="toolbar">
        <a asp-controller="Tattoos" asp-action="Create" asp-route-clientId="@Model.Id" class="btn btn-primary">Nova sessao</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Editar cliente</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>
</section>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="panel h-100">
            <div class="panel-body">
                <h2 class="h5 mb-3">Dados do cliente</h2>
                <dl class="row detail-list">
                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.CellPhone)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.CellPhone)</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Email)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Email)</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.BirthDate)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.BirthDate)</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.CPF)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.CPF)</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Address)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Address)</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Instagram)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Instagram)</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel h-100">
            <div class="panel-body">
                <h2 class="h5 mb-3">Resumo</h2>
                <div class="metric mb-3">
                    <div class="metric-label">Sessoes registradas</div>
                    <p class="metric-value">@tattoos.Count</p>
                </div>
                <div class="metric">
                    <div class="metric-label">Total pago</div>
                    <p class="metric-value">@totalPaid.ToString("C")</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="page-header">
    <div>
        <div class="page-kicker">Historico</div>
        <h2 class="h4 mb-0">Sessoes</h2>
    </div>
</div>

@if (tattoos.Any())
{
    <div class="panel table-panel">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Descricao</th>
                    <th>Pagamento</th>
                    <th class="text-end">Valor</th>
                    <th class="text-end">Acoes</th>
                </tr>
            </thead>
            <tbody>
@foreach (var tattoo in tattoos)
{
                <tr>
                    <td>@tattoo.SessionDate.ToShortDateString()</td>
                    <td>@tattoo.PostScript</td>
                    <td>@tattoo.PaymentMethod</td>
                    <td class="text-end">@tattoo.ValuePaid.ToString("C")</td>
                    <td>
                        <div class="actions">
                            <a asp-controller="Tattoos" asp-action="Details" asp-route-id="@tattoo.Id" class="btn btn-sm btn-outline-secondary">Detalhes</a>
                            <a asp-controller="Tattoos" asp-action="Edit" asp-route-id="@tattoo.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                        </div>
                    </td>
                </tr>
}
            </tbody>
        </table>
    </div>
}
else
{
    <div class="panel">
        <div class="empty-state">Este cliente ainda nao possui sessoes registradas.</div>
    </div>
}
