@model WebAppTattoo.Models.Client

@{
    ViewData["Title"] = "Excluir cliente";
}

<section class="page-header">
    <div>
        <div class="page-kicker">Confirmacao</div>
        <h1>Excluir cliente</h1>
        <p class="page-description">Revise os dados antes de confirmar a exclusao.</p>
    </div>
</section>

<div class="panel danger-panel">
    <div class="panel-body">
        <h2 class="h5 mb-3">@Model.Name</h2>
        <dl class="row detail-list">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CellPhone)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.CellPhone)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Email)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CPF)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.CPF)</dd>
        </dl>

        <form asp-action="Delete" class="toolbar justify-content-start mt-4">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Excluir cliente" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </form>
    </div>
</div>
