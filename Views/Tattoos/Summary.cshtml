@model WebAppTattoo.Models.ViewModels.TattooSummaryViewModel

@{
    ViewData["Title"] = "Resumo de Tatuagens";
}

<h1>Resumo de Tatuagens</h1>

<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Summary">
            <h4>Pesquisar por Periodo</h4>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="StartDate" class="control-label">Data de Inicio</label>
                <input asp-for="StartDate" type="date" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EndDate" class="control-label">Data de Fim</label>
                <input asp-for="EndDate" type="date" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Pesquisar" class="btn btn-primary mt-2" />
            </div>
        </form>
    </div>
</div>

@if (Model.HasResult)
{
    <hr />
    <h3 class="mt-4">Resultados da Pesquisa (@Model.StartDate.ToShortDateString() ate @Model.EndDate.ToShortDateString())</h3>
    <dl class="row">
        <dt class="col-sm-4">Total de Tatuagens:</dt>
        <dd class="col-sm-8">@Model.TotalTattoos</dd>

        <dt class="col-sm-4">Valor Total Arrecadado:</dt>
        <dd class="col-sm-8">@Model.TotalValue.ToString("C")</dd>
    </dl>
}

<div>
    <a asp-action="Index">Voltar para a Lista</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
