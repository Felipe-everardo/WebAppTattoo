@model WebAppTattoo.Models.ViewModels.TattooSummaryViewModel

@{
    ViewData["Title"] = "Resumo financeiro";
}

<section class="page-header">
    <div>
        <div class="page-kicker">Financeiro</div>
        <h1>Resumo financeiro</h1>
        <p class="page-description">Filtre sessoes por periodo e acompanhe o total arrecadado.</p>
    </div>
    <div class="toolbar">
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>
</section>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="panel">
            <div class="panel-body">
                <form asp-action="Summary">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-group mb-3">
                        <label asp-for="StartDate" class="control-label">Data de inicio</label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="EndDate" class="control-label">Data de fim</label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>
                    <input type="submit" value="Pesquisar" class="btn btn-primary" />
                </form>
            </div>
        </div>
    </div>

    @if (Model.HasResult)
    {
        <div class="col-lg-7">
            <div class="panel h-100">
                <div class="panel-body">
                    <h2 class="h5 mb-3">@Model.StartDate.ToShortDateString() ate @Model.EndDate.ToShortDateString()</h2>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="metric">
                                <div class="metric-label">Total de sessoes</div>
                                <p class="metric-value">@Model.TotalTattoos</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="metric">
                                <div class="metric-label">Valor arrecadado</div>
                                <p class="metric-value">@Model.TotalValue.ToString("C")</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
