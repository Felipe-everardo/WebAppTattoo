@model WebAppTattoo.Models.Tattoo

@{
    ViewData["Title"] = "Detalhes da sessao";
}

<h1>Detalhes da sessao</h1>

<div>
    <h4>@Model.Client?.Name</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.SessionDate)</dt>
        <dd class="col-sm-9">@Model.SessionDate.ToShortDateString()</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PostScript)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.PostScript)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PaymentMethod)</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.PaymentMethod)</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ValuePaid)</dt>
        <dd class="col-sm-9">@Model.ValuePaid.ToString("C")</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Client)</dt>
        <dd class="col-sm-9">
            <a asp-controller="Clients" asp-action="Details" asp-route-id="@Model.ClientId">@Model.Client?.Name</a>
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
</div>
